{
  "name": "atelier-design-system",
  "private": true,
  "version": "0.17.0",
  "type": "module",
  "description": "Atelier — a quiet, editorial design system built with React + Vite.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "cli": "node packages/cli/bin/atelier.js",
    "build:ds": "npm run build --workspace=@atelier/ds",
    "pack:ds": "npm run pack --workspace=@atelier/ds",
    "smoke:ds": "npm run smoke --workspace=@atelier/ds",
    "build:cli": "npm run build --workspace=@atelier/cli",
    "pack:cli": "npm run pack --workspace=@atelier/cli",
    "smoke:cli": "npm run smoke --workspace=@atelier/cli",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.0.2",
    "typescript": "^6.0.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.4"
  }
}
