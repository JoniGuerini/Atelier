{
  "name": "@atelier/ds",
  "version": "0.1.0",
  "description": "Atelier — a quiet, editorial design system. React components, hooks, and tokens.",
  "type": "module",
  "license": "MIT",
  "author": "Jonathan Guerini",
  "homepage": "https://atelier.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathan-guerini/atelier.git",
    "directory": "packages/ds"
  },
  "keywords": [
    "react",
    "design-system",
    "components",
    "ui",
    "editorial",
    "typography",
    "zero-deps",
    "tree-shakeable"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.js",
      "require": "./dist/components.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js",
      "require": "./dist/hooks.cjs"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js",
      "require": "./dist/tokens.cjs"
    },
    "./contrast": {
      "types": "./dist/contrast.d.ts",
      "import": "./dist/contrast.js",
      "require": "./dist/contrast.cjs"
    },
    "./styles.css": "./dist/atelier.css",
    "./package.json": "./package.json"
  },
  "scripts": {
    "sync": "node ./scripts/sync-sources.mjs",
    "build": "npm run sync && vite build",
    "pack": "npm run build && npm pack",
    "smoke": "node ./scripts/smoke.mjs",
    "clean": "rm -rf dist src/_app *.tgz"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
