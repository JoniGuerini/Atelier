{
  "$schema": "https://atelier-ds.com/registry-schema.json",
  "name": "@atelier/ds",
  "version": "0.9.0",
  "components": [
    { "name": "Button",         "category": "primitive", "path": "src/ds/primitives.tsx",     "note": "Primary, ghost, link", "deps": [] },
    { "name": "Input",          "category": "form",      "path": "src/ds/primitives.tsx",     "note": "Text/email/password",  "deps": [] },
    { "name": "Switch",         "category": "form",      "path": "src/ds/primitives.tsx",     "note": "Toggle",                "deps": [] },
    { "name": "Card",           "category": "layout",    "path": "src/ds/Card.tsx",           "note": "Editorial card",        "deps": [] },
    { "name": "Tabs",           "category": "navigation","path": "src/ds/Tabs.tsx",           "note": "5 variantes",           "deps": [] },
    { "name": "Drawer",         "category": "overlay",   "path": "src/ds/Drawer.tsx",         "note": "Side sheet · 4 lados",  "deps": ["useFocusTrap", "useScrollLock"] },
    { "name": "Popover",        "category": "overlay",   "path": "src/ds/Popover.tsx",        "note": "Anchored panel",        "deps": ["useClickOutside"] },
    { "name": "Toaster",        "category": "feedback",  "path": "src/ds/Toaster.tsx",        "note": "Queue · 5 variantes",   "deps": [] },
    { "name": "DataTable",      "category": "data",      "path": "src/ds/DataTable.tsx",      "note": "Composable · sort · filter · virtualize", "deps": ["RangeSlider", "Combobox", "DatePicker", "Pagination"] },
    { "name": "Combobox",       "category": "form",      "path": "src/ds/Combobox.tsx",       "note": "Searchable select",     "deps": ["useClickOutside"] },
    { "name": "RangeSlider",    "category": "form",      "path": "src/ds/RangeSlider.tsx",   "note": "1 ou 2 thumbs",         "deps": [] },
    { "name": "Calendar",       "category": "form",      "path": "src/ds/Calendar.tsx",       "note": "Single · range · multi","deps": [] },
    { "name": "DatePicker",     "category": "form",      "path": "src/ds/DatePicker.tsx",     "note": "Input + Calendar",      "deps": ["Calendar"] },
    { "name": "ColorPicker",    "category": "form",      "path": "src/ds/ColorPicker.tsx",   "note": "HSV + hex/RGB",         "deps": [] },
    { "name": "MarkdownViewer", "category": "data",      "path": "src/ds/MarkdownViewer.tsx", "note": "Parser próprio",        "deps": [] },
    { "name": "Form",           "category": "form",      "path": "src/ds/Form.tsx",           "note": "Composable",            "deps": ["Field"] },
    { "name": "Field",          "category": "form",      "path": "src/ds/Field.tsx",          "note": "Label + hint + error",  "deps": [] },
    { "name": "Stepper",        "category": "navigation","path": "src/ds/Stepper.tsx",        "note": "Multi-step indicator",  "deps": [] },
    { "name": "Pagination",     "category": "navigation","path": "src/ds/Pagination.tsx",     "note": "Editorial paginator",   "deps": [] },
    { "name": "Breadcrumbs",    "category": "navigation","path": "src/ds/Breadcrumbs.tsx",    "note": "Trail + separator",     "deps": [] },
    { "name": "TreeView",       "category": "navigation","path": "src/ds/TreeView.tsx",       "note": "Hierarchical · roving", "deps": ["useRovingTabIndex"] },
    { "name": "Carousel",       "category": "data",      "path": "src/ds/Carousel.tsx",       "note": "Swipe touch + dots",    "deps": [] },
    { "name": "VirtualList",    "category": "data",      "path": "src/ds/VirtualList.tsx",    "note": "Windowing performance", "deps": ["useResizeObserver"] },
    { "name": "Chart",          "category": "data",      "path": "src/ds/Chart.tsx",          "note": "Bar/Line/Area/Pie/Radar/Sparkline", "deps": [] },
    { "name": "Skeleton",       "category": "feedback",  "path": "src/ds/Skeleton.tsx",       "note": "Loading placeholder",   "deps": [] },
    { "name": "EmptyState",     "category": "feedback",  "path": "src/ds/EmptyState.tsx",     "note": "Editorial empty",       "deps": [] },
    { "name": "Alert",          "category": "feedback",  "path": "src/ds/Alert.tsx",          "note": "Info/ok/warn/danger",   "deps": [] },
    { "name": "Timeline",       "category": "data",      "path": "src/ds/Timeline.tsx",       "note": "Vertical/horizontal",   "deps": [] },
    { "name": "TagInput",       "category": "form",      "path": "src/ds/TagInput.tsx",       "note": "Chips removíveis",      "deps": [] },
    { "name": "DropdownMenu",   "category": "overlay",   "path": "src/ds/DropdownMenu.tsx",   "note": "Menu de ações",         "deps": ["useClickOutside"] },
    { "name": "ContextMenu",    "category": "overlay",   "path": "src/ds/ContextMenu.tsx",    "note": "Right-click",           "deps": ["useClickOutside"] },
    { "name": "Dialog",         "category": "overlay",   "path": "src/ds/Dialog.tsx",         "note": "Modal · focus trap",    "deps": ["useFocusTrap", "useFocusReturn", "useScrollLock"] },
    { "name": "ResizablePanels","category": "layout",    "path": "src/ds/ResizablePanels.tsx","note": "Split panels",          "deps": [] },
    { "name": "DragDrop",       "category": "data",      "path": "src/ds/DragDrop.tsx",       "note": "Sortable · DnD kit",    "deps": [] },
    { "name": "KBD",            "category": "primitive", "path": "src/ds/KBD.tsx",            "note": "Keys · combo · inline code", "deps": [] },
    { "name": "Motion",         "category": "primitive", "path": "src/ds/Motion.tsx",         "note": "Transition · Fade · Slide · ScrollReveal", "deps": ["usePrefersReducedMotion", "useIntersectionObserver"] }
  ],
  "hooks": [
    { "name": "useMediaQuery",            "path": "src/lib/hooks/useMediaQuery.ts" },
    { "name": "usePrefersReducedMotion",  "path": "src/lib/hooks/usePrefersReducedMotion.ts" },
    { "name": "useWindowSize",            "path": "src/lib/hooks/useWindowSize.ts" },
    { "name": "useIntersectionObserver",  "path": "src/lib/hooks/useIntersectionObserver.ts" },
    { "name": "useResizeObserver",        "path": "src/lib/hooks/useResizeObserver.ts" },
    { "name": "useClickOutside",          "path": "src/lib/hooks/useClickOutside.ts" },
    { "name": "useScrollLock",            "path": "src/lib/hooks/useScrollLock.ts" },
    { "name": "useEventListener",         "path": "src/lib/hooks/useEventListener.ts" },
    { "name": "useKeyPress",              "path": "src/lib/hooks/useKeyPress.ts" },
    { "name": "useLocalStorage",          "path": "src/lib/hooks/useLocalStorage.ts" },
    { "name": "useDebounce",              "path": "src/lib/hooks/useDebounce.ts" },
    { "name": "useThrottle",              "path": "src/lib/hooks/useThrottle.ts" },
    { "name": "useControllableState",     "path": "src/lib/hooks/useControllableState.ts" },
    { "name": "usePrevious",              "path": "src/lib/hooks/usePrevious.ts" },
    { "name": "useUpdateEffect",          "path": "src/lib/hooks/useUpdateEffect.ts" },
    { "name": "useFocusTrap",             "path": "src/lib/hooks/useFocusTrap.ts" },
    { "name": "useFocusReturn",           "path": "src/lib/hooks/useFocusReturn.ts" },
    { "name": "useRovingTabIndex",        "path": "src/lib/hooks/useRovingTabIndex.ts" }
  ]
}
